import { useState, useEffect, useRef } from "react";
import { useNavigate } from "react-router-dom";
import { DashboardLayout } from "@/components/layout/DashboardLayout";
import { useAuth } from "@/contexts/AuthContext";
import { Button } from "@/components/ui/button";
import { Input } from "@/components/ui/input";
import { Badge } from "@/components/ui/badge";
import { Avatar, AvatarFallback } from "@/components/ui/avatar";
import {
  Sparkles, Send, Mic, Bot, Search, Star,
  Zap, Globe, Clock, BrainCircuit, MapPin,
  CheckCircle, Plus,
} from "lucide-react";
import { cn } from "@/lib/utils";

interface Message {
  id: string;
  role: "ai" | "user";
  content: string;
  timestamp: Date;
}

interface FreelancerMatch {
  id: string;
  name: string;
  location: string;
  skills: string[];
  hourlyRate: number;
  bio: string;
  matchScore: number;
  matchReason: string;
  estimatedTotal: number;
}

const API_URL = "http://localhost:5000/api/ai/assistant";

const AIAssistantPage = () => {
  const navigate = useNavigate();
  const { user } = useAuth();
  const [messages, setMessages] = useState<Message[]>([]);
  const [input, setInput] = useState("");
  const [isTyping, setIsTyping] = useState(false);
  const [matches, setMatches] = useState<FreelancerMatch[]>([]);
  const [sessionId, setSessionId] = useState<string | null>(null);
  const [stage, setStage] = useState<string>("UNDERSTAND");
  const [memory, setMemory] = useState<any>(null);
  const [sessions, setSessions] = useState<any[]>([]);
  const [isSidebarOpen, setIsSidebarOpen] = useState(true);
  const [isListening, setIsListening] = useState(false);
  const messagesEndRef = useRef<HTMLDivElement>(null);

  const startListening = () => {
    if (!('webkitSpeechRecognition' in window)) {
      alert("Speech recognition not supported in this browser.");
      return;
    }
    
    if (isListening) {
      // @ts-ignore
      if (window._recognition) window._recognition.stop();
      setIsListening(false);
      return;
    }

    // @ts-ignore
    const recognition = new window.webkitSpeechRecognition();
    recognition.continuous = true;
    recognition.interimResults = true;
    recognition.lang = 'en-US';

    recognition.onstart = () => {
      setIsListening(true);
      // @ts-ignore
      window._recognition = recognition;
    }
    recognition.onend = () => setIsListening(false);
    recognition.onresult = (event: any) => {
      let fullTranscript = '';
      for (let i = event.resultIndex; i < event.results.length; i++) {
        fullTranscript += event.results[i][0].transcript;
      }
      setInput(fullTranscript);
    };

    recognition.start();
  };

  const scrollToBottom = () => {
    messagesEndRef.current?.scrollIntoView({ behavior: "smooth" });
  };

  useEffect(() => {
    scrollToBottom();
  }, [messages, isTyping]);

  useEffect(() => {
    if (user?.id) fetchSessions();
  }, [user]);

  const fetchSessions = async () => {
    try {
      const resp = await fetch(`${API_URL}/sessions?clientId=${user?.id}`);
      const data = await resp.json();
      if (data.success) setSessions(data.sessions);
    } catch (e) {
      console.error("Fetch sessions error:", e);
    }
  };

  const loadSession = async (sid: string) => {
    setIsTyping(true);
    try {
       const resp = await fetch(`${API_URL}/session/${sid}`);
       const data = await resp.json();
       if (data.success) {
          setSessionId(data.sessionId);
          setStage(data.stage);
          setMemory(data.memory);
          setMatches(data.matches || []);
          
          if (data.history) {
             const msgs = data.history.map((m: any, i: number) => ({
                id: sid + i,
                role: m.role as "ai" | "user",
                content: m.content,
                timestamp: new Date()
             }));
             setMessages(msgs);
          }
       }
    } catch (e) {
       console.error("Load session error:", e);
    } finally {
       setIsTyping(false);
    }
  }

  const handleSend = async (content: string = input) => {
    if (!content.trim()) return;

    const userMsg: Message = {
      id: Date.now().toString(),
      role: "user",
      content,
      timestamp: new Date(),
    };
    setMessages((prev) => [...prev, userMsg]);
    setInput("");
    setIsTyping(true);

    try {
      const response = await fetch(`${API_URL}/message`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          message: content,
          sessionId: sessionId || undefined,
          clientName: user?.name || "Client",
          clientId: user?.id,
        }),
      });

      const data = await response.json();
      if (!response.ok) throw new Error(data.error || "Something went wrong");

      if (data.sessionId) {
          setSessionId(data.sessionId);
          if (!sessionId) fetchSessions();
      }
      
      if (data.stage) setStage(data.stage);
      if (data.memory) setMemory(data.memory);

      setIsTyping(false);
      setMessages((prev) => [...prev, {
        id: (Date.now() + 1).toString(),
        role: "ai",
        content: data.reply,
        timestamp: new Date(),
      }]);

      if (data.matches && data.matches.length > 0) {
        setMatches(data.matches);
      } else {
        setMatches([]);
      }

    } catch (error: any) {
      setIsTyping(false);
      setMessages((prev) => [...prev, {
        id: (Date.now() + 1).toString(),
        role: "ai",
        content: "Sorry, something went wrong. Please try again.",
        timestamp: new Date(),
      }]);
    }
  };

  const handleClear = () => {
    setMessages([]);
    setMatches([]);
    setSessionId(null);
    setStage("UNDERSTAND");
    setMemory(null);
  };

  return (
    <DashboardLayout>
      <div className="flex flex-col lg:flex-row h-[calc(100vh-100px)] gap-4 p-2 lg:p-4 bg-background/50 overflow-hidden">

        {/* Sidebar Left: Chat History */}
        <div className={cn(
             "h-full flex flex-col bg-card/40 rounded-[2rem] border border-border/50 shadow-xl backdrop-blur-xl transition-all duration-300 overflow-hidden",
             isSidebarOpen ? "w-[280px]" : "w-0 opacity-0 pointer-events-none"
        )}>
           <div className="p-4 flex items-center justify-between border-b border-white/5">
              <h3 className="font-black text-xs uppercase tracking-tighter text-muted-foreground flex items-center gap-2">
                 <Clock className="h-3 w-3" /> Historic Syncs
              </h3>
              <Button variant="ghost" size="icon" className="h-7 w-7 rounded-full bg-primary/5 hover:bg-primary/10" onClick={handleClear}>
                 <Sparkles className="h-3 w-3 text-primary" />
              </Button>
           </div>
           
           <div className="flex-1 overflow-y-auto px-2 py-4 space-y-1 custom-scrollbar">
              <Button 
                variant="ghost" 
                className="w-full justify-start gap-3 h-12 rounded-2xl bg-primary text-white hover:bg-primary/90 mb-6 shadow-lg shadow-primary/20"
                onClick={handleClear}
              >
                <Plus className="h-4 w-4" />
                <span className="font-bold text-xs uppercase">New Protocol</span>
              </Button>

              {sessions.length === 0 ? (
                <div className="py-20 text-center space-y-4 opacity-30">
                   <Bot className="h-10 w-10 mx-auto" />
                   <p className="text-[10px] font-black uppercase tracking-widest">No Active Archives</p>
                </div>
              ) : (
                sessions.map((s) => (
                  <button
                    key={s.sessionId}
                    onClick={() => loadSession(s.sessionId)}
                    className={cn(
                        "w-full p-4 rounded-2xl text-left transition-all group border mb-1",
                        sessionId === s.sessionId ? "bg-primary/10 border-primary/20 shadow-sm" : "hover:bg-white/5 border-transparent"
                    )}
                  >
                     <div className="flex items-start gap-3">
                        <div className={cn(
                            "h-9 w-9 rounded-xl flex items-center justify-center shrink-0 shadow-sm transition-colors",
                            sessionId === s.sessionId ? "bg-primary text-white" : "bg-muted group-hover:bg-primary/20 group-hover:text-primary"
                        )}>
                           <Sparkles className="h-4 w-4" />
                        </div>
                        <div className="min-w-0 flex-1">
                           <p className={cn(
                             "font-black text-[11px] truncate leading-tight uppercase tracking-tight",
                             sessionId === s.sessionId ? "text-primary" : "text-foreground/80"
                           )}>{s.title || "Standard Sync"}</p>
                           <p className="text-[9px] text-muted-foreground font-medium truncate mt-1 leading-relaxed">{s.lastMessage || "Empty session"}</p>
                        </div>
                     </div>
                  </button>
                ))
              )}
           </div>
           
           <div className="p-5 border-t border-white/5 mt-auto">
              <div className="flex items-center gap-3 px-2 py-2 rounded-2xl hover:bg-white/5 transition-colors cursor-pointer">
                 <Avatar className="h-9 w-9 border-2 border-primary/20 rounded-xl overflow-hidden">
                    <AvatarFallback className="bg-primary/10 text-primary text-[10px] font-black uppercase italic">{user?.name?.[0]}</AvatarFallback>
                 </Avatar>
                 <div className="flex-1 min-w-0">
                    <p className="font-bold text-xs truncate leading-none mb-1 uppercase tracking-tighter">{user?.name}</p>
                    <p className="text-[8px] text-muted-foreground font-black uppercase tracking-widest leading-none italic opacity-50">Authorized Client</p>
                 </div>
              </div>
           </div>
        </div>

        {/* Chat Interface (Main Center) */}
        <div className="flex-1 flex flex-col bg-card/60 rounded-[2.5rem] border border-border shadow-2xl overflow-hidden relative backdrop-blur-xl">
          <div className="px-8 py-6 border-b border-white/5 bg-white/5 backdrop-blur-3xl flex items-center justify-between">
            <div className="flex items-center gap-6">
               <div className="flex flex-col gap-1.5 cursor-pointer p-2 hover:bg-white/5 rounded-xl transition-all group" onClick={() => setIsSidebarOpen(!isSidebarOpen)}>
                  <div className={cn("h-0.5 bg-primary transition-all duration-300", isSidebarOpen ? "w-6" : "w-4")} />
                  <div className="h-0.5 w-6 bg-primary" />
                  <div className={cn("h-0.5 bg-primary transition-all duration-300", isSidebarOpen ? "w-6" : "w-8")} />
               </div>
               <div>
                  <h2 className="font-black text-xl uppercase tracking-tighter text-foreground flex items-center gap-3">
                     AI Project Architect <Sparkles className="h-4 w-4 text-primary animate-pulse" />
                  </h2>
                  <div className="flex items-center gap-2 mt-1">
                    <span className="flex h-1.5 w-1.5 rounded-full bg-emerald-500 shadow-[0_0_8px_rgba(16,185,129,0.5)]" />
                    <span className="text-[9px] text-muted-foreground font-black uppercase tracking-[0.2em] italic">
                       Core Analysis: {stage}
                    </span>
                  </div>
               </div>
            </div>
            
            <div className="hidden md:flex items-center gap-3">
               <div className="pl-4 pr-5 py-2.5 rounded-[1.25rem] bg-gradient-to-tr from-primary/10 via-background to-purple-600/10 border border-primary/20 backdrop-blur-3xl flex items-center gap-4 relative overflow-hidden group hover:border-primary transition-all">
                  <div className="absolute inset-0 bg-white/[0.02] group-hover:bg-transparent transition-colors" />
                  <div className="flex -space-x-2 relative shrink-0">
                     {[1,2,3].map(i => (
                        <div key={i} className="h-7 w-7 rounded-full border-2 border-background bg-gradient-to-br from-primary/20 to-purple-600/20 flex items-center justify-center shadow-lg transform hover:-translate-y-1 transition-transform">
                           <Sparkles className="h-3 w-3 text-primary" />
                        </div>
                     ))}
                  </div>
                  <div className="flex flex-col relative">
                     <span className="text-[9px] font-black uppercase tracking-[0.15em] text-primary leading-none">Architect Cluster</span>
                     <span className="text-[8px] font-bold text-muted-foreground uppercase tracking-widest mt-1 opacity-60 italic">Synchronized Active</span>
                  </div>
               </div>
            </div>
          </div>

          <div className="flex-1 overflow-y-auto p-6 lg:p-12 space-y-12 custom-scrollbar relative">
            <div className="max-w-4xl mx-auto space-y-14">
            {messages.length === 0 ? (
              <div className="h-full flex flex-col items-center justify-center text-center space-y-14 py-20 translate-y-[-2%] overflow-visible">
                <div className="relative group">
                   <div className="absolute inset-0 bg-primary/20 blur-[130px] rounded-full group-hover:bg-primary/30 transition-all duration-1000" />
                   <div className="h-32 w-32 bg-gradient-to-tr from-primary via-blue-600 to-purple-600 rounded-[2.8rem] flex items-center justify-center mx-auto mb-14 relative shadow-[0_30px_60px_rgba(79,70,229,0.5)] transform hover:scale-110 hover:rotate-3 transition-all duration-500 ease-out z-10 border border-white/20">
                     <Sparkles className="h-14 w-14 text-white drop-shadow-xl" />
                   </div>
                   <h3 className="text-5xl font-black tracking-tighter text-foreground uppercase italic underline decoration-primary/50 decoration-8 underline-offset-[16px] mb-8">
                     Start New Build?
                   </h3>
                   <p className="text-muted-foreground text-xl max-w-xl mx-auto font-medium leading-relaxed opacity-80">
                     I am your persistent autonomous architect. Describe your vision, and I'll orchestrate the entire technical execution and negotiation.
                   </p>
                </div>

                <div className="grid grid-cols-1 md:grid-cols-2 gap-5 w-full max-w-3xl px-4">
                  {[
                    { text: "Launch a SaaS MVP", icon: Zap, desc: "Fast-track technical build" },
                    { text: "Creative UI Brand Identity", icon: Globe, desc: "Design & UX Strategy" },
                    { text: "AI Automation System", icon: BrainCircuit, desc: "Workflow efficiency" },
                    { text: "Fullstack Mobile App", icon: Send, desc: "Cross-platform reach" },
                  ].map((chip) => (
                    <button
                      key={chip.text}
                      onClick={() => handleSend(chip.text)}
                      className="group p-6 text-left rounded-[2rem] border border-white/5 bg-white/[0.03] hover:bg-white/[0.07] hover:border-primary/30 transition-all duration-500 relative overflow-hidden shadow-xl"
                    >
                      <div className="flex items-center gap-6">
                         <div className="h-14 w-14 rounded-2xl bg-white/5 flex items-center justify-center group-hover:bg-primary/20 group-hover:text-primary transition-all duration-500 shrink-0 border border-white/10 shadow-inner">
                             <chip.icon className="h-7 w-7" />
                         </div>
                         <div className="min-w-0">
                            <p className="font-black text-sm uppercase tracking-tight text-white group-hover:text-primary transition-colors truncate leading-none mb-2">{chip.text}</p>
                            <p className="text-[10px] font-black text-muted-foreground uppercase tracking-widest truncate opacity-40 leading-none">{chip.desc}</p>
                         </div>
                      </div>
                    </button>
                  ))}
                </div>
              </div>
            ) : (
              <div className="space-y-16">
                  {messages.map((msg, idx) => (
                    <div key={idx} className={cn("flex w-full animate-in slide-in-from-bottom-8 fade-in-0 duration-700", msg.role === "user" ? "justify-end" : "justify-start")}>
                      <div className={cn("max-w-[85%] flex gap-6", msg.role === "user" ? "flex-row-reverse" : "flex-row")}>
                        <Avatar className="h-14 w-14 border-4 border-white/5 shadow-2xl shrink-0 mt-2 rounded-2xl overflow-hidden">
                          {msg.role === "ai" ? (
                            <div className="h-full w-full bg-gradient-to-tr from-primary to-purple-600 flex items-center justify-center">
                              <Sparkles className="h-6 w-6 text-white" />
                            </div>
                          ) : (
                            <AvatarFallback className="bg-white/10 text-primary text-sm font-black italic uppercase">{user?.name?.[0]}</AvatarFallback>
                          )}
                        </Avatar>
                        
                        <div className="space-y-4">
                           {msg.role === "ai" && idx === messages.length - 1 && memory && (
                             <div className="px-4 py-2 bg-primary/10 border border-primary/20 rounded-xl inline-flex items-center gap-2.5 animate-pulse">
                               <BrainCircuit className="h-4 w-4 text-primary" />
                               <span className="text-[11px] font-black uppercase tracking-[0.1em] text-primary">Synchronized Analysis Active</span>
                             </div>
                           )}

                          <div className={cn("p-7 rounded-[2.4rem] text-[16px] leading-[1.7] shadow-2xl relative overflow-hidden border",
                            msg.role === "user" ? 
                              "bg-primary text-white rounded-tr-none shadow-primary/20 font-medium border-primary" : 
                              "bg-[#1a1c23] text-foreground/90 rounded-tl-none border-white/5 backdrop-blur-4xl")}>
                               {msg.content}
                          </div>
                        </div>
                      </div>
                    </div>
                  ))}
                  
                  {matches.length > 0 && (
                    <div className="grid grid-cols-1 md:grid-cols-2 gap-10 animate-in zoom-in-95 slide-in-from-top-12 duration-1000 pb-12">
                      {matches.map((f) => (
                        <div key={f.id} className="group p-10 rounded-[3.5rem] bg-[#111218] border border-white/10 shadow-[0_40px_80px_rgba(0,0,0,0.6)] space-y-10 hover:border-primary/50 transition-all relative overflow-hidden ring-1 ring-white/5">
                           <div className="absolute inset-0 bg-gradient-to-br from-primary/10 via-transparent to-purple-600/10 opacity-0 group-hover:opacity-100 transition-opacity" />
                           
                           <div className="flex items-start justify-between relative z-10 gap-6">
                              <div className="flex items-center gap-6 min-w-0">
                                 <div className="relative shrink-0">
                                    <Avatar className="h-24 w-24 rounded-[2rem] border-4 border-white/5 shadow-2xl ring-1 ring-white/10">
                                       <AvatarFallback className="bg-primary/20 text-primary text-3xl font-black italic uppercase">{f.name[0]}</AvatarFallback>
                                    </Avatar>
                                    <div className="absolute -bottom-2 -right-2 bg-emerald-500 text-white text-[12px] font-black px-4 py-2 rounded-2xl shadow-xl border-2 border-[#111218] z-20">
                                       {f.matchScore}% 
                                    </div>
                                 </div>
                                 <div className="min-w-0">
                                    <h4 className="font-black text-2xl uppercase tracking-tighter text-white mb-2 leading-none">{f.name}</h4>
                                    <div className="flex items-center gap-3">
                                       <div className="h-6 w-6 rounded-lg bg-amber-500/20 flex items-center justify-center shrink-0 border border-amber-500/10">
                                          <Star className="h-3.5 w-3.5 text-amber-500 fill-amber-500" />
                                       </div>
                                       <span className="text-[11px] font-black text-muted-foreground uppercase tracking-[0.3em]">{f.skills[0]} ARCHITECT</span>
                                    </div>
                                 </div>
                              </div>
                              <div className="text-right shrink-0">
                                 <p className="text-[13px] font-black text-muted-foreground/30 uppercase tracking-[0.2em] line-through decoration-red-500/50 mb-2">${f.hourlyRate}/HR</p>
                                 <p className="text-4xl font-black text-primary tracking-tighter leading-none">${f.estimatedTotal.toLocaleString()}</p>
                              </div>
                           </div>

                           <div className="relative z-10 px-1 border-l-2 border-primary/20 py-2">
                              <p className="text-[14px] text-foreground/70 font-medium leading-[1.8] italic px-6 opacity-80">
                                 "{f.matchReason}"
                              </p>
                           </div>

                           <div className="flex flex-wrap gap-2.5 relative z-10">
                              {f.skills.slice(0, 3).map(s => (
                                 <Badge key={s} variant="secondary" className="h-8 text-[10px] font-black uppercase px-4 bg-white/5 hover:bg-primary/20 hover:text-white transition-all border-white/10">{s}</Badge>
                              ))}
                           </div>

                           <Button 
                              className="w-full h-18 rounded-[1.8rem] bg-primary text-white font-black text-sm uppercase tracking-[0.2em] shadow-[0_25px_50px_rgba(79,70,229,0.4)] hover:scale-[1.03] hover:shadow-primary/60 active:scale-95 transition-all relative z-10 border-t-2 border-white/20 py-8"
                              onClick={() => handleSend(`Pick ${f.name}`)}
                           >
                              Engage Strategy <Send className="ml-4 h-5 w-5" />
                           </Button>
                        </div>
                      ))}
                    </div>
                  )}
              </div>
            )}
            </div>
            {isTyping && (
              <div className="flex justify-start max-w-4xl mx-auto pt-6">
                  <div className="bg-[#1a1c23] p-6 px-10 rounded-[2.5rem] rounded-tl-none flex gap-2.5 border border-white/5 shadow-2xl">
                    <span className="w-2 h-2 bg-primary rounded-full animate-bounce" style={{ animationDelay: "0ms" }} />
                    <span className="h-2 w-2 bg-primary/60 rounded-full animate-bounce" style={{ animationDelay: "150ms" }} />
                    <span className="w-2 h-2 bg-primary/30 rounded-full animate-bounce" style={{ animationDelay: "300ms" }} />
                  </div>
              </div>
            )}
            <div ref={messagesEndRef} />
          </div>

          <div className="p-10 lg:p-14 bg-[#0d0e12]/80 border-t border-white/10 backdrop-blur-5xl mt-auto relative z-30">
            <div className="relative flex items-center gap-6 max-w-5xl mx-auto">
              <div className="relative flex-1 group">
                <Input
                  placeholder="Initiate project protocol or ask anything..."
                  className="pr-24 h-20 bg-white/[0.04] border-white/10 rounded-[1.8rem] focus-visible:ring-primary/40 text-lg font-medium placeholder:text-muted-foreground/20 ring-offset-background transition-all px-8 shadow-inner"
                  value={input}
                  onChange={(e) => setInput(e.target.value)}
                  onKeyDown={(e) => e.key === "Enter" && !isTyping && handleSend()}
                  disabled={isTyping}
                />
                <div className="absolute right-4 top-1/2 -translate-y-1/2 flex items-center gap-2">
                   {input.length === 0 && (
                      <Button 
                        size="icon" 
                        variant="ghost" 
                        className={cn("h-12 w-12 text-muted-foreground hover:text-primary rounded-2xl transition-all", isListening && "text-red-500 bg-red-500/10 animate-pulse")}
                        onClick={startListening}
                      >
                         <Mic className="h-6 w-6" />
                      </Button>
                   )}
                   <Button 
                      variant="ghost" 
                      size="icon" 
                      className="h-12 w-12 text-muted-foreground hover:text-primary rounded-2xl transition-all"
                   >
                     <Search className="h-6 w-6" />
                   </Button>
                </div>
              </div>
              <Button
                className="h-20 px-12 rounded-[1.8rem] bg-primary text-white font-black uppercase tracking-[0.1em] flex items-center gap-4 shadow-[0_20px_40px_rgba(79,70,229,0.3)] hover:scale-[1.05] hover:shadow-primary/50 flex-shrink-0 transition-all border-t-2 border-white/20 text-lg"
                onClick={() => handleSend()}
                disabled={!input.trim() || isTyping}
              >
                Sync <Send className="h-6 w-6" />
              </Button>
            </div>
            <p className="text-[11px] text-center text-muted-foreground mt-8 font-black uppercase tracking-[0.3em] opacity-30 italic">SkillBridge Unified AI Architect Protocol v2.5.0 • Multi-Session Engine Active</p>
          </div>

        </div>
      </div>
    </DashboardLayout>
  );
};

export default AIAssistantPage;
